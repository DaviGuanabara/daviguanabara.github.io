\NeedsTeXFormat{LaTeX2e}
\ProvidesFile{resume-base.sty}[2026/07/15 Resume Engineering System base style]

\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{lmodern}
\RequirePackage[margin=1.45cm]{geometry}
\RequirePackage{microtype}
\RequirePackage{xcolor}
\RequirePackage{enumitem}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{ifthen}

\setlist[itemize]{leftmargin=1.2em,itemsep=0.15em,topsep=0.2em,parsep=0pt,partopsep=0pt}
\urlstyle{same}

\newcommand{\ResumeName}[1]{\def\ResumeStoredName{#1}}
\newcommand{\ResumeTitle}[1]{\def\ResumeStoredTitle{#1}}
\newcommand{\ResumeEmail}[1]{\def\ResumeStoredEmail{#1}}
\newcommand{\ResumePhone}[1]{\def\ResumeStoredPhone{#1}}
\newcommand{\ResumeLocation}[1]{\def\ResumeStoredLocation{#1}}
\newcommand{\ResumeHeaderLine}[1]{\def\ResumeStoredHeaderLine{#1}}

\newcommand{\ResumeMakeHeader}{%
  {\LARGE\bfseries \ResumeStoredName\par}%
  \vspace{0.25em}%
  {\normalsize \ResumeStoredTitle\par}%
  \vspace{0.45em}%
  {\small
    \ResumeStoredEmail
    \hspace{1.2em}%
    \ResumeStoredPhone
    \hspace{1.2em}%
    \ResumeStoredLocation\par
  }%
  \ifx\ResumeStoredHeaderLine\undefined\else
    \vspace{0.2em}{\small \ResumeStoredHeaderLine\par}%
  \fi
  \vspace{0.7em}%
  \hrule height 0.5pt
  \vspace{0.8em}%
}

\newcommand{\ResumeSection}[1]{%
  \vspace{0.55em}%
  {\large\bfseries #1\par}%
  \vspace{0.18em}%
  \hrule height 0.4pt
  \vspace{0.45em}%
}

\newcommand{\ResumeEntry}[4]{%
  \textbf{#1}\hfill\textbf{#3}\par
  \ifthenelse{\equal{#2}{}}{}{%
    {\emph{#2}}\ifthenelse{\equal{#4}{}}{}{ \hfill #4}\par
  }%
}

\newcommand{\ResumeDetailListStart}{\begin{itemize}}
\newcommand{\ResumeDetailListEnd}{\end{itemize}}
\newcommand{\ResumeDetail}[1]{\item #1}

\newcommand{\ResumeSkillGroup}[2]{%
  \textbf{#1}: #2\par
}

\newcommand{\ResumeLinkItem}[2]{%
  \textbf{#1}: #2\par
}

\newcommand{\ResumeLanguageItem}[2]{%
  \textbf{#1}: #2\par
}
